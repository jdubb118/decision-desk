# Decision Desk environment variables (all optional — sensible defaults apply)

# Server
# PORT=3335
# HOST=127.0.0.1                                # set to 0.0.0.0 to expose on LAN

# Storage
# DECISION_DESK_DATA_DIR=./data                 # where DB + uploads live
# DECISION_DESK_DB=./data/decision-desk.db

# Identity
# DECISION_DESK_REVIEWER=reviewer               # the human reviewing the queue

# File serving (colon-separated absolute paths the /api/file/:id route is allowed to read)
# DECISION_DESK_SAFE_ROOTS=/abs/path/one:/abs/path/two

# Brand context markdown directory (optional — for /api/brand-profile)
# DECISION_DESK_BRAND_CONTEXT_DIR=./data/brand-context

# Calendar import paths — JSON map of brand → file path
# DECISION_DESK_CALENDAR_PATHS={"default":"/abs/path/calendar-2026.json"}

# Webhook notifications (optional)
# DECISION_DESK_WEBHOOK_URL=https://example.com/decision-desk-hook
# DECISION_DESK_WEBHOOK_SECRET=set-a-long-random-string-to-enable-hmac-signing

# Optional shared-secret token. When set, all mutating /api/* requests must
# send Authorization: Bearer <token>. Reads stay open.
# DECISION_DESK_WRITE_TOKEN=change-me-to-a-long-random-string

# Demo seed — populates a fresh DB with 3 sample cards so the reviewer UI
# isn't empty on first visit. Skipped automatically if the DB already has
# rows. Set to false to suppress in production deployments.
# DECISION_DESK_DEMO_SEED=false
